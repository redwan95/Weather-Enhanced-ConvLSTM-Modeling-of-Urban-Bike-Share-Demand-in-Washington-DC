def train_model(model, X_spatial, X_external, y, user_type):
    """Train with early stopping"""

    print(f"\n🚂 Training {user_type} model...")

    # Split data (80% train, 20% test)
    split_idx = int(0.8 * len(X_spatial))

    X_spatial_train = X_spatial[:split_idx]
    X_spatial_test = X_spatial[split_idx:]
    X_external_train = X_external[:split_idx]
    X_external_test = X_external[split_idx:]
    y_train = y[:split_idx]
    y_test = y[split_idx:]

    # Callbacks
    early_stop = keras.callbacks.EarlyStopping(
        monitor='val_loss',
        patience=10,
        restore_best_weights=True,
        verbose=1
    )

    reduce_lr = keras.callbacks.ReduceLROnPlateau(
        monitor='val_loss',
        factor=0.5,
        patience=5,
        min_lr=1e-6,
        verbose=1
    )

    # Train
    history = model.fit(
        [X_spatial_train, X_external_train],
        y_train,
        validation_data=([X_spatial_test, X_external_test], y_test),
        epochs=config.EPOCHS,
        batch_size=config.BATCH_SIZE,
        callbacks=[early_stop, reduce_lr],
        verbose=1
    )

    # Evaluate
    test_loss, test_mae = model.evaluate([X_spatial_test, X_external_test], y_test, verbose=0)

    # Calculate R²
    predictions = model.predict([X_spatial_test, X_external_test], verbose=0)
    ss_res = np.sum((y_test - predictions) ** 2)
    ss_tot = np.sum((y_test - np.mean(y_test)) ** 2)
    r2 = 1 - (ss_res / ss_tot)

    print(f"\n📊 {user_type.capitalize()} Model Performance:")
    print(f"   MAE: {test_mae:.2f}")
    print(f"   RMSE: {np.sqrt(test_loss):.2f}")
    print(f"   R²: {r2:.3f}")

    # Plot training history
    fig, axes = plt.subplots(1, 2, figsize=(14, 4))

    axes[0].plot(history.history['loss'], label='Train Loss')
    axes[0].plot(history.history['val_loss'], label='Val Loss')
    axes[0].set_xlabel('Epoch')
    axes[0].set_ylabel('Loss (MSE)')
    axes[0].set_title(f'{user_type.capitalize()} - Training Loss')
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)

    axes[1].plot(history.history['mae'], label='Train MAE')
    axes[1].plot(history.history['val_mae'], label='Val MAE')
    axes[1].set_xlabel('Epoch')
    axes[1].set_ylabel('MAE')
    axes[1].set_title(f'{user_type.capitalize()} - MAE')
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)

    plt.tight_layout()
    plt.savefig(os.path.join(config.OUTPUT_DIR, f'training_history_{user_type}.png'), dpi=300, bbox_inches='tight')
    plt.show()

    return history, (X_spatial_test, X_external_test, y_test), predictions

