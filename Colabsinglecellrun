# CELL 12: Compute Spatial Dependency Matrix (FIXED SHAP ALTERNATIVE)
# ============================================================================
def compute_spatial_dependency_matrix(model, X_spatial, X_external, grid_size, n_samples=50):
    """
    Compute spatial dependencies using permutation importance
    This is more reliable than SHAP for this use case
    """

    print("🧮 Computing spatial dependency matrix...")

    n_cells = grid_size ** 2
    phi_matrix = np.zeros((n_cells, n_cells))

    # Sample data
    sample_indices = np.random.choice(len(X_spatial), min(n_samples, len(X_spatial)), replace=False)
    X_spatial_sample = X_spatial[sample_indices]
    X_external_sample = X_external[sample_indices]

    # Baseline predictions
    baseline_pred = model.predict(
        [X_spatial_sample, X_external_sample],
        verbose=0
    )

    # For each target cell
    for target_cell in range(n_cells):
        target_row = target_cell // grid_size
        target_col = target_cell % grid_size

        baseline_target = baseline_pred[:, target_row, target_col, :]

        # For each source cell
        for source_cell in range(n_cells):
            if source_cell == target_cell:
                continue

            source_row = source_cell // grid_size
            source_col = source_cell % grid_size

            # Perturb source cell (zero out)
            X_perturbed = X_spatial_sample.copy()
            X_perturbed[:, :, source_row, source_col, :] = 0

            perturbed_pred = model.predict(
                [X_perturbed, X_external_sample],
                verbose=0
            )

            perturbed_target = perturbed_pred[:, target_row, target_col, :]

            # Compute influence (mean absolute change)
            influence = np.mean(np.abs(baseline_target - perturbed_target))
            phi_matrix[target_cell, source_cell] = influence

        if (target_cell + 1) % 10 == 0:
            print(f"   Processed {target_cell + 1}/{n_cells} cells")

    print("✅ Spatial dependency matrix computed!")

    return phi_matrix

