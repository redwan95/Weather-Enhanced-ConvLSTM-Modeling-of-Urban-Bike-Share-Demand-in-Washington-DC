def create_interactive_map(grid_df, phi_matrix, user_type):
    """Create interactive Folium map"""

    # Calculate net influence
    outward = phi_matrix.sum(axis=0)
    inward = phi_matrix.sum(axis=1)
    net_influence = outward - inward

    grid_df = grid_df.copy()
    grid_df['net_influence'] = net_influence
    grid_df['outward'] = outward
    grid_df['inward'] = inward

    # Create map
    center_lat = grid_df['center_lat'].mean()
    center_lon = grid_df['center_lon'].mean()

    m = folium.Map(
        location=[center_lat, center_lon],
        zoom_start=11,
        tiles='CartoDB positron'
    )

    # Normalize for coloring
    if net_influence.max() != net_influence.min():
        norm_influence = (net_influence - net_influence.min()) / (net_influence.max() - net_influence.min())
    else:
        norm_influence = np.zeros_like(net_influence)

    # Add grid cells
    for idx, cell in grid_df.iterrows():
        color_val = norm_influence[idx]

        # Red-Blue color map
        if color_val > 0.5:
            r = 255
            b = int(255 * (1 - (color_val - 0.5) * 2))
        else:
            r = int(255 * color_val * 2)
            b = 255
        g = 100

        color_hex = '#%02x%02x%02x' % (r, g, b)

        folium.Rectangle(
            bounds=[
                [cell['min_lat'], cell['min_lon']],
                [cell['max_lat'], cell['max_lon']]
            ],
            color=color_hex,
            fill=True,
            fillColor=color_hex,
            fillOpacity=0.6,
            weight=2,
            popup=folium.Popup(f"""
                <b>Cell {cell['cell_id']}</b><br>
                Net Influence: {cell['net_influence']:.3f}<br>
                Outward: {cell['outward']:.3f}<br>
                Inward: {cell['inward']:.3f}
            """, max_width=200)
        ).add_to(m)

    # Save
    map_file = os.path.join(config.OUTPUT_DIR, f'spatial_map_{user_type}.html')
    m.save(map_file)
    print(f"🗺️  Interactive map saved: {map_file}")

    return m

