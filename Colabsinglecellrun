def plot_spatial_dependencies(phi_matrix, grid_df, user_type, top_k=10):
    """Visualize spatial dependency patterns"""

    fig, axes = plt.subplots(1, 2, figsize=(20, 8))

    # Heatmap
    im = axes[0].imshow(phi_matrix, cmap='RdBu_r', aspect='auto')
    axes[0].set_title(f'{user_type.capitalize()} Spatial Dependency Matrix (Φ)',
                     fontsize=14, fontweight='bold')
    axes[0].set_xlabel('Source Cell', fontsize=12)
    axes[0].set_ylabel('Target Cell', fontsize=12)
    plt.colorbar(im, ax=axes[0], label='Dependency Strength')

    # Net influence
    outward_influence = phi_matrix.sum(axis=0)
    inward_influence = phi_matrix.sum(axis=1)

    grid_plot = grid_df.copy()
    grid_plot['outward'] = outward_influence
    grid_plot['inward'] = inward_influence
    grid_plot['net_influence'] = outward_influence - inward_influence

    influence_grid = grid_plot.pivot(index='row', columns='col', values='net_influence')
    im2 = axes[1].imshow(influence_grid, cmap='RdBu', aspect='auto')
    axes[1].set_title(f'{user_type.capitalize()} Net Spatial Influence',
                     fontsize=14, fontweight='bold')
    axes[1].set_xlabel('Column', fontsize=12)
    axes[1].set_ylabel('Row', fontsize=12)
    plt.colorbar(im2, ax=axes[1], label='Net Influence (Outward - Inward)')

    # Add top arrows
    top_pairs = []
    for i in range(len(phi_matrix)):
        for j in range(len(phi_matrix)):
            if i != j and phi_matrix[i, j] > 0:
                top_pairs.append((i, j, phi_matrix[i, j]))

    top_pairs = sorted(top_pairs, key=lambda x: x[2], reverse=True)[:top_k]

    for source, target, strength in top_pairs:
        source_row = source // config.GRID_SIZE
        source_col = source % config.GRID_SIZE
        target_row = target // config.GRID_SIZE
        target_col = target % config.GRID_SIZE

        axes[1].arrow(
            source_col, source_row,
            target_col - source_col, target_row - source_row,
            head_width=0.3,
            head_length=0.3,
            fc='green',
            ec='green',
            alpha=0.6,
            width=strength / phi_matrix.max() * 0.1
        )

    plt.tight_layout()
    filepath = os.path.join(config.OUTPUT_DIR, f'spatial_dependencies_{user_type}.png')
    plt.savefig(filepath, dpi=300, bbox_inches='tight')
    plt.show()
    print(f"✅ Saved: {filepath}")

    return grid_plot

