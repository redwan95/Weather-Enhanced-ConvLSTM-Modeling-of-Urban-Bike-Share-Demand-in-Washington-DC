def aggregate_to_grid(trips, grid, time_interval=30):
    """Aggregate trips to grid cells and time intervals"""

    print("🔄 Aggregating trips to grid...")

    # Assign trips to grid cells
    trips = trips.copy()
    trips['start_cell'] = -1
    trips['end_cell'] = -1

    for _, cell in grid.iterrows():
        # Start locations
        mask = (
            (trips['start_lat'] >= cell['min_lat']) &
            (trips['start_lat'] < cell['max_lat']) &
            (trips['start_lng'] >= cell['min_lon']) &
            (trips['start_lng'] < cell['max_lon'])
        )
        trips.loc[mask, 'start_cell'] = cell['cell_id']

        # End locations
        mask = (
            (trips['end_lat'] >= cell['min_lat']) &
            (trips['end_lat'] < cell['max_lat']) &
            (trips['end_lng'] >= cell['min_lon']) &
            (trips['end_lng'] < cell['max_lon'])
        )
        trips.loc[mask, 'end_cell'] = cell['cell_id']

    # Remove trips outside grid
    trips = trips[(trips['start_cell'] != -1) & (trips['end_cell'] != -1)]

    print(f"   Trips within grid: {len(trips):,}")

    # Create time intervals
    trips['time_bin'] = trips['started_at'].dt.floor(f'{time_interval}min')

    # Aggregate pickups
    pickups = trips.groupby(['time_bin', 'start_cell', 'member_casual']).size().reset_index(name='pickups')

    # Aggregate dropoffs
    dropoffs = trips.groupby(['time_bin', 'end_cell', 'member_casual']).size().reset_index(name='dropoffs')
    dropoffs = dropoffs.rename(columns={'end_cell': 'start_cell'})

    # Merge
    aggregated = pickups.merge(
        dropoffs,
        on=['time_bin', 'start_cell', 'member_casual'],
        how='outer'
    ).fillna(0)

    # Rename column
    aggregated = aggregated.rename(columns={'start_cell': 'cell_id'})

    print(f"✅ Aggregated to {len(aggregated):,} spatiotemporal records")

    return aggregated

