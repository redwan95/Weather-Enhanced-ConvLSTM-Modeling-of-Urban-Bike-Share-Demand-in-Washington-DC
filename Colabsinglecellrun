def load_bikeshare_data(csv_path):
    """
    Load and preprocess Capital Bikeshare trip data
    """

    print("📥 Loading bike-sharing data...")

    # Read CSV
    df = pd.read_csv(csv_path)

    print(f"   Raw data: {len(df):,} trips")

    # Parse timestamps
    df['started_at'] = pd.to_datetime(df['started_at'])
    df['ended_at'] = pd.to_datetime(df['ended_at'])

    # Calculate trip duration
    df['duration_min'] = (df['ended_at'] - df['started_at']).dt.total_seconds() / 60

    # Clean data
    df_clean = df[
        (df['duration_min'] >= 1) &  # At least 1 minute
        (df['duration_min'] <= 720) &  # Max 12 hours
        (df['start_lat'].notna()) &
        (df['end_lat'].notna()) &
        (df['member_casual'].isin(['member', 'casual']))
    ].copy()

    print(f"   After cleaning: {len(df_clean):,} trips")
    print(f"   Members: {(df_clean['member_casual']=='member').sum():,}")
    print(f"   Casual: {(df_clean['member_casual']=='casual').sum():,}")

    # Filter to study area
    bbox = config.STUDY_AREA['bbox']
    df_clean = df_clean[
        (df_clean['start_lat'] >= bbox['min_lat']) &
        (df_clean['start_lat'] <= bbox['max_lat']) &
        (df_clean['start_lng'] >= bbox['min_lon']) &
        (df_clean['start_lng'] <= bbox['max_lon']) &
        (df_clean['end_lat'] >= bbox['min_lat']) &
        (df_clean['end_lat'] <= bbox['max_lat']) &
        (df_clean['end_lng'] >= bbox['min_lon']) &
        (df_clean['end_lng'] <= bbox['max_lon'])
    ]

    print(f"   In study area: {len(df_clean):,} trips")

    # Display sample
    print("\n📋 Sample data:")
    print(df_clean[['started_at', 'start_lat', 'start_lng', 'end_lat', 'end_lng', 'member_casual']].head())

    return df_clean

