# CELL 10: Build Enhanced Model
# ============================================================================
def build_enhanced_model(spatial_shape, external_dim, grid_size):
    """Enhanced ConvLSTM model with external features"""

    # Spatial input
    spatial_input = keras.Input(shape=spatial_shape[1:], name='spatial_input')

    # ConvLSTM layers
    x = layers.ConvLSTM2D(
        filters=64,
        kernel_size=(3, 3),
        padding='same',
        return_sequences=True,
        activation='relu',
        kernel_regularizer=keras.regularizers.l2(0.001)
    )(spatial_input)
    x = layers.BatchNormalization()(x)
    x = layers.Dropout(0.2)(x)

    x = layers.ConvLSTM2D(
        filters=64,
        kernel_size=(3, 3),
        padding='same',
        return_sequences=True,
        activation='relu',
        kernel_regularizer=keras.regularizers.l2(0.001)
    )(x)
    x = layers.BatchNormalization()(x)
    x = layers.Dropout(0.2)(x)

    x = layers.ConvLSTM2D(
        filters=64,
        kernel_size=(3, 3),
        padding='same',
        return_sequences=False,
        activation='relu',
        kernel_regularizer=keras.regularizers.l2(0.001)
    )(x)
    x = layers.BatchNormalization()(x)

    # External features
    external_input = keras.Input(shape=(external_dim,), name='external_input')
    ext = layers.Dense(32, activation='relu')(external_input)
    ext = layers.BatchNormalization()(ext)
    ext = layers.Dense(64, activation='relu')(ext)

    # Broadcast external to spatial
    ext_spatial = layers.Reshape((1, 1, 64))(ext)
    ext_spatial = layers.UpSampling2D(size=(grid_size, grid_size))(ext_spatial)

    # Combine
    combined = layers.Concatenate()([x, ext_spatial])

    # Output
    output = layers.Conv2D(2, (1, 1), activation='relu', name='output')(combined)

    model = keras.Model(
        inputs=[spatial_input, external_input],
        outputs=output
    )

    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=config.LEARNING_RATE),
        loss='mse',
        metrics=['mae']
    )

    return model

