def prepare_training_data(aggregated, weather, grid, user_type='member'):
    """Prepare spatiotemporal sequences with external features"""

    print(f"🏗️  Preparing training data for {user_type} users...")

    # Filter by user type
    data = aggregated[aggregated['member_casual'] == user_type].copy()

    # Create full time grid
    all_times = pd.date_range(
        data['time_bin'].min(),
        data['time_bin'].max(),
        freq=f'{config.TIME_INTERVAL}min'
    )

    all_cells = range(1, config.GRID_SIZE ** 2 + 1)

    # Create full spatiotemporal grid
    full_grid = pd.MultiIndex.from_product(
        [all_times, all_cells],
        names=['time_bin', 'cell_id']
    ).to_frame(index=False)

    # Merge with actual data
    data = full_grid.merge(data, on=['time_bin', 'cell_id'], how='left')
    data[['pickups', 'dropoffs']] = data[['pickups', 'dropoffs']].fillna(0)

    # Add weather features
    weather['datetime'] = weather['datetime'].dt.floor(f'{config.TIME_INTERVAL}min')
    data = data.merge(
        weather.rename(columns={'datetime': 'time_bin'}),
        on='time_bin',
        how='left'
    )
    data = data.ffill().bfill()

    # Add temporal features
    data['hour'] = data['time_bin'].dt.hour
    data['day_of_week'] = data['time_bin'].dt.dayofweek
    data['is_weekend'] = (data['day_of_week'] >= 5).astype(int)

    # Add spatial features
    grid_info = grid[['cell_id', 'center_lat', 'center_lon', 'row', 'col']]
    data = data.merge(grid_info, on='cell_id', how='left')

    # Create sequences
    timesteps = sorted(data['time_bin'].unique())

    X_spatial = []
    X_external = []
    y_pickups = []
    y_dropoffs = []

    for t_idx in range(config.LOOKBACK_STEPS, len(timesteps)):
        # Historical spatial data
        spatial_history = []
        for lookback in range(config.LOOKBACK_STEPS):
            t = timesteps[t_idx - config.LOOKBACK_STEPS + lookback]
            t_data = data[data['time_bin'] == t].sort_values('cell_id')

            grid_pickups = t_data['pickups'].values.reshape(config.GRID_SIZE, config.GRID_SIZE, 1)
            grid_dropoffs = t_data['dropoffs'].values.reshape(config.GRID_SIZE, config.GRID_SIZE, 1)

            spatial_history.append(np.concatenate([grid_pickups, grid_dropoffs], axis=-1))

        X_spatial.append(np.stack(spatial_history, axis=0))

        # External features
        current_t = timesteps[t_idx]
        current_data = data[data['time_bin'] == current_t].iloc[0]

        external_features = np.array([
            current_data['temperature'] / 30.0,  # Normalize
            current_data['precipitation'],
            current_data['windspeed'] / 20.0,
            current_data['humidity'] / 100.0,
            current_data['hour'] / 24.0,
            current_data['day_of_week'] / 7.0,
            current_data['is_weekend']
        ])
        X_external.append(external_features)

        # Target
        target_data = data[data['time_bin'] == current_t].sort_values('cell_id')
        y_pickups.append(target_data['pickups'].values.reshape(config.GRID_SIZE, config.GRID_SIZE, 1))
        y_dropoffs.append(target_data['dropoffs'].values.reshape(config.GRID_SIZE, config.GRID_SIZE, 1))

    X_spatial = np.array(X_spatial)
    X_external = np.array(X_external)
    y = np.concatenate([np.array(y_pickups), np.array(y_dropoffs)], axis=-1)

    print(f"✅ Created sequences:")
    print(f"   Spatial shape: {X_spatial.shape}")
    print(f"   External shape: {X_external.shape}")
    print(f"   Target shape: {y.shape}")
    print(f"   Time range: {timesteps[config.LOOKBACK_STEPS]} to {timesteps[-1]}")

    return X_spatial, X_external, y, data

